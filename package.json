{
  "name": "blog-publisher",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Blogger(Blogspot) 마크다운 자동 발행 + 로컬 웹 관리 시스템",
  "scripts": {
    "get-token": "node scripts/get-token.mjs",
    "publish": "node scripts/publish.mjs",
    "publish:dry": "node scripts/publish.mjs --dry-run",
    "web": "node --env-file=.env server/index.mjs",
    "dev": "node --env-file=.env --watch server/index.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "turndown": "^7.2.0"
  }
}
