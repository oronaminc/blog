# ── Blogger 자동 발행 설정 ─────────────────────────────────
# 아래 값들을 채운 뒤 이 파일을 .env 로 복사하세요:  cp .env.example .env
# (GitHub Actions 에서는 이 값들을 저장소 Settings > Secrets 에 등록합니다)

# 블로그 ID (숫자). `npm run get-token` 을 실행하면 자동으로 알려줍니다.
BLOG_ID=

# Google Cloud Console > 사용자 인증 정보 에서 만든 OAuth 2.0 클라이언트(데스크톱 앱)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# `npm run get-token` 으로 발급받는 리프레시 토큰
GOOGLE_REFRESH_TOKEN=
